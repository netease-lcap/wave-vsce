{
  "name": "wave-vscode-chat",
  "displayName": "Wave AI 聊天",
  "description": "基于 Wave Agent SDK 的 VS Code AI 聊天界面",
  "version": "0.0.1",
  "publisher": "wave-code",
  "repository": {
    "type": "git",
    "url": "ssh://git@g.hz.netease.com:22222/vusion/wave-vsce.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "files": [
    "dist/",
    "webview/dist/",
    "LICENSE"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wave-code.openChat",
        "title": "打开 AI 聊天",
        "category": "Wave"
      }
    ],
    "keybindings": [
      {
        "command": "wave-code.openChat",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "clean": "node -e \"const fs=require('fs'); ['dist', 'webview/dist'].forEach(d => {try{fs.rmSync(d, {recursive:true, force:true})}catch(e){}})\"",
    "prepackage": "npm run clean",
    "compile": "webpack --mode production",
    "watch": "webpack --watch --mode development --devtool cheap-source-map",
    "package": "webpack --mode production --devtool false",
    "test": "npm run test:playwright",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/diff": "^7.0.2",
    "@types/glob": "^8.1.0",
    "@types/node": "18.x",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.95.0",
    "css-loader": "^6.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.4",
    "typescript": "^4.9.4",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@vscode/codicons": "^0.0.43",
    "diff": "^8.0.2",
    "dompurify": "^3.3.0",
    "glob": "^13.0.0",
    "marked": "^9.1.6",
    "wave-agent-sdk": "file:wave-agent-sdk-0.0.8.tgz"
  }
}

{
  "name": "wave-code-chat",
  "version": "0.0.1",
  "private": true,
  "description": "Wave VSCode Chat Extension Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "watch": "pnpm -r run watch",
    "test": "pnpm --filter @wave-code-chat/webview run test",
    "test:ui": "pnpm --filter @wave-code-chat/webview run test:ui",
    "clean": "pnpm -r run clean",
    "package": "pnpm --filter @wave-code-chat/vsce run package",
    "dev": "pnpm run watch"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
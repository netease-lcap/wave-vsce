{
  "name": "wave-vscode-chat",
  "displayName": "Wave 代码智聊",
  "description": "Wave code for VS Code",
  "version": "0.0.2",
  "publisher": "wave-code",
  "icon": "LOGO.png",
  "repository": {
    "type": "git",
    "url": "ssh://git@g.hz.netease.com:22222/vusion/wave-vsce.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "files": [
    "dist/",
    "webview/dist/",
    "LOGO.png",
    "logo.svg",
    "bin/",
    "LICENSE"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "waveChatView": [
        {
          "id": "waveChat",
          "name": "代码智聊",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "waveChatView",
          "title": "Wave",
          "icon": "logo.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "wave-code.openChatSidebar",
        "title": "在侧边栏打开代码智聊",
        "category": "Wave"
      },
      {
        "command": "wave-code.openChatTab",
        "title": "在新标签页打开代码智聊",
        "category": "Wave"
      },
      {
        "command": "wave-code.openChatWindow",
        "title": "在新窗口打开代码智聊",
        "category": "Wave"
      },
      {
        "command": "wave-code.focusView",
        "title": "聚焦到聊天输入框",
        "category": "Wave"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); ['dist', 'webview/dist'].forEach(d => {try{fs.rmSync(d, {recursive:true, force:true})}catch(e){}})\"",
    "prepackage": "npm run clean",
    "compile": "npm run compile:backend && npm run compile:frontend",
    "watch": "npm run watch:backend & npm run watch:frontend",
    "compile:backend": "tsc",
    "compile:frontend": "ONLY_FRONTEND=true webpack --mode development --devtool source-map",
    "watch:backend": "tsc --watch",
    "watch:frontend": "npm run compile:frontend -- --watch",
    "webpack:prod": "webpack --mode production --devtool false",
    "package": "node scripts/package.js",
    "test": "npm run test:playwright",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.0.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.95.0",
    "css-loader": "^6.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.43",
    "diff": "^8.0.2",
    "dompurify": "^3.3.0",
    "marked": "^9.1.6",
    "mermaid": "^11.12.2",
    "wave-agent-sdk": "file:wave-agent-sdk-1768378983.tgz"
  }
}

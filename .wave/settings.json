{
  "language": "Chinese",
  "env": {
    "WAVE_MAX_INPUT_TOKENS": "200000"
  },
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(npm run compile*)",
      "Bash(npm run package*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(npm test*)",
      "Bash(npx playwright test*)",
      "Bash(npm run test*)"
    ]
  }
}